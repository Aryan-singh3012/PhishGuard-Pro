{
  "manifest_version": 3,
  "name": "AI PhishGuard Pro",
  "version": "2.2",
  "description": "Advanced AI-powered Phishing Detection with Cloud Sync and SSL Analysis.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://gqoxufoyjhkyxxffclrl.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon48.png",
      "48": "icons/icon48.png",
      "128": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon48.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}